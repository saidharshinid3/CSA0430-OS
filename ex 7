#include <stdio.h>

int main() {
    int bt[] = {7, 4, 1};

    for (int i = 0; i < 3; i++)
        for (int j = i+1; j < 3; j++)
            if (bt[i] > bt[j]) {
                int t = bt[i];
                bt[i] = bt[j];
                bt[j] = t;
            }

    printf("Execution Order:\n");
    for (int i = 0; i < 3; i++)
        printf("%d ", bt[i]);

    return 0;
}
